-- Guild Info Webhook Script (Executor‑Friendly)
-- Sends guild stats and member contributions to Discord

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local HttpService = game:GetService("HttpService")

-- CONFIG
local WEBHOOK_URL = "https://discordapp.com/api/webhooks/1518875088630317056/VfzprlJYnbUMiR_Kqw7SCafrAyx5v8HIRAORW7_XypwxCq-8E36JZEQM0NMs0rGHnNSN"  -- <-- CHANGE THIS
local CHECK_INTERVAL = 300  -- 5 minutes

-- State
local lastData = {}
local lastCheckTime = 0

-- Helper: safely get text from a GUI object path
local function getText(obj, ...)
    if not obj then return nil end
    local current = obj
    for _, childName in ipairs({...}) do
        current = current:FindFirstChild(childName)
        if not current then return nil end
    end
    if current:IsA("TextLabel") or current:IsA("TextButton") then
        return current.Text
    end
    return nil
end

-- Main data gathering – wrapped in pcall to prevent crashes
local function getGuildInfo()
    local info = {
        guildName = "Unknown",
        tag = "???",
        score = "0",
        rank = "N/A",
        memberCount = "0",
        members = {}
    }

    local success, result = pcall(function()
        local gui = LocalPlayer.PlayerGui
        if not gui then return end

        local viewPage = gui:FindFirstChild("ViewGuildPage")
        if not viewPage or not viewPage.Visible then return end

        local main = viewPage:FindFirstChild("MainPage")
        if not main then return end

        local content = main:FindFirstChild("Content")
        if not content then return end

        -- Guild name & tag
        local nameRank = content:FindFirstChild("GuildName_Rank")
        if nameRank then
            local txt = nameRank.Text or ""
            local tag = string.match(txt, "%[(.-)%]")
            if tag then
                info.tag = tag
                info.guildName = string.match(txt, "^(.-)%s*%[") or txt
            else
                info.guildName = txt
            end
        end

        -- Total contribution & rank
        local guildInfo = content:FindFirstChild("GuildInfo")
        if guildInfo then
            local total = guildInfo:FindFirstChild("TotalContribution")
            if total then
                local txt = total.Text or ""
                local score = string.match(txt, "Score:%s*(.-)%s*•")
                local rank = string.match(txt, "Rank%s*#(%d+,?%d*)")
                if score then info.score = string.gsub(score, "%s", "") end
                if rank then info.rank = "#" .. rank end
            end
        end

        -- Member count
        local countLabel = content:FindFirstChild("MemberCountTextLabel1")
        if countLabel then
            info.memberCount = countLabel.Text or "0"
        end

        -- Members list
        local scroll = content:FindFirstChild("ScrollingFrame")
        if scroll then
            for _, child in ipairs(scroll:GetChildren()) do
                if child:IsA("Frame") and string.match(child.Name, "^Member_%d+$") then
                    local container = child:FindFirstChild("ContainerFrame")
                    if container then
                        local username = getText(container, "Username") or "Unknown"
                        local weekly = getText(container, "Contributions", "Weekly", "TextLabel") or "0"
                        table.insert(info.members, {
                            username = username,
                            contribution = weekly
                        })
                    end
                end
            end
            -- Sort members by name (optional)
            table.sort(info.members, function(a, b)
                return a.username < b.username
            end)
        end
    end)

    return info
end

-- Check if data changed (deep compare)
local function hasDataChanged(old, new)
    if not old or not new then return true end
    if old.guildName ~= new.guildName then return true end
    if old.tag ~= new.tag then return true end
    if old.score ~= new.score then return true end
    if old.rank ~= new.rank then return true end
    if old.memberCount ~= new.memberCount then return true end
    if #old.members ~= #new.members then return true end
    for i = 1, #old.members do
        if old.members[i].username ~= new.members[i].username then return true end
        if old.members[i].contribution ~= new.members[i].contribution then return true end
    end
    return false
end

-- Format Discord message
local function formatMessage(data)
    if not data or #data.members == 0 then
        return "No guild data available (or guild page not open)."
    end

    local lines = {
        string.format("**[%s] %s**", data.tag or "???", data.guildName or "Unknown"),
        string.format("Score: %s  •  Rank: %s", data.score or "0", data.rank or "N/A"),
        string.format("Members: %s", data.memberCount or "0"),
        "─────────────────"
    }

    -- Add up to 25 members to avoid message length limits
    local maxMembers = 25
    for i, m in ipairs(data.members) do
        if i > maxMembers then
            table.insert(lines, string.format("… and %d more", #data.members - maxMembers))
            break
        end
        table.insert(lines, string.format("%s     %s", m.username or "Unknown", m.contribution or "0"))
    end

    return table.concat(lines, "\n")
end

-- Send to Discord
local function sendToDiscord(data)
    if WEBHOOK_URL == "YOUR_DISCORD_WEBHOOK_URL_HERE" then
        warn("⚠️  Please set your Discord webhook URL in the script!")
        return
    end

    local message = formatMessage(data)
    local payload = HttpService:JSONEncode({ content = message })

    local ok, err = pcall(function()
        HttpService:PostAsync(WEBHOOK_URL, payload, Enum.HttpContentType.ApplicationJson)
    end)

    if not ok then
        warn("Failed to send webhook: " .. tostring(err))
    end
end

-- Update function
local function updateGuildInfo()
    local newData = getGuildInfo()
    if hasDataChanged(lastData, newData) then
        sendToDiscord(newData)
        -- Deep copy
        lastData = {
            guildName = newData.guildName,
            tag = newData.tag,
            score = newData.score,
            rank = newData.rank,
            memberCount = newData.memberCount,
            members = {}
        }
        for _, m in ipairs(newData.members) do
            table.insert(lastData.members, {
                username = m.username,
                contribution = m.contribution
            })
        end
        lastCheckTime = tick()
    end
end

-- Start monitoring
local function startMonitoring()
    print("Guild Info Monitor started. Updates every " .. CHECK_INTERVAL .. " seconds.")
    updateGuildInfo() -- initial send

    game:GetService("RunService").Heartbeat:Connect(function()
        if tick() - lastCheckTime >= CHECK_INTERVAL then
            updateGuildInfo()
        end
    end)

    -- Also trigger on GUI visibility change
    local viewPage = LocalPlayer.PlayerGui:FindFirstChild("ViewGuildPage")
    if viewPage then
        viewPage:GetPropertyChangedSignal("Visible"):Connect(function()
            wait(0.5) -- wait for UI to refresh
            updateGuildInfo()
        end)
    end
end

-- Wait for GUI to appear
local function waitForGuildPage()
    local gui = LocalPlayer.PlayerGui
    if gui and gui:FindFirstChild("ViewGuildPage") then
        startMonitoring()
        return
    end

    print("Waiting for ViewGuildPage to appear...")
    local conn
    conn = gui.ChildAdded:Connect(function(child)
        if child.Name == "ViewGuildPage" then
            conn:Disconnect()
            wait(1)
            startMonitoring()
        end
    end)

    -- Timeout after 30s
    wait(30)
    if conn and conn.Connected then
        conn:Disconnect()
        print("Timeout: ViewGuildPage not found. Make sure you're in a guild.")
    end
end

-- Run
waitForGuildPage()
