-- Guild Info Webhook Script for Roblox
-- Sends guild information to Discord via webhook every 5 minutes or on change

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local HttpService = game:GetService("HttpService")
local RunService = game:GetService("RunService")

-- CONFIGURATION
local WEBHOOK_URL = "https://discordapp.com/api/webhooks/1518875088630317056/VfzprlJYnbUMiR_Kqw7SCafrAyx5v8HIRAORW7_XypwxCq-8E36JZEQM0NMs0rGHnNSN" -- Replace with your actual webhook URL
local CHECK_INTERVAL = 300 -- 5 minutes in seconds

-- State variables
local lastData = {}
local currentData = {}
local lastCheckTime = 0

-- Function to get a nil instance (helper function)
local function getNil(name, class)
    for _, v in next, getnilinstances() do
        if v.ClassName == class and v.Name == name then
            return v
        end
    end
    return nil
end

-- Strip RichText tags (e.g. <font color="...">text</font>) since these GUIs use RichText
local function stripRichText(text)
    if not text then return text end
    return (string.gsub(text, "<[^>]->", ""))
end

-- Many of these GUI containers are Frames that hold the actual text in a
-- child TextLabel/TextButton (e.g. GuildName_Rank.TextLabel), rather than
-- being a text object themselves. This pulls text from a named child object
-- if it's directly a text object, or from its first TextLabel/TextButton
-- descendant otherwise. Works regardless of GUI Visible state since it's
-- pure instance-tree indexing, same as Dex.
local function getTextFrom(parent, childName)
    if not parent then return nil end
    local obj = parent:FindFirstChild(childName)
    if not obj then return nil end

    if obj:IsA("TextLabel") or obj:IsA("TextButton") then
        return stripRichText(obj.Text)
    end

    local nested = obj:FindFirstChildWhichIsA("TextLabel")
        or obj:FindFirstChildWhichIsA("TextButton")
        or obj:FindFirstChildOfClass("TextLabel")
        or obj:FindFirstChildOfClass("TextButton")
    if nested then
        return stripRichText(nested.Text)
    end

    -- Fall back to a deeper search in case the text object isn't a direct child
    local descendant = obj:FindFirstChild("TextLabel", true) or obj:FindFirstChild("TextButton", true)
    if descendant then
        return stripRichText(descendant.Text)
    end

    return nil
end

-- Function to safely get text from a GUI path
local function getTextFromPath(path)
    local success, result = pcall(function()
        local current = path[1]
        for i = 2, #path do
            current = current[path[i]]
        end
        if current and (current:IsA("TextLabel") or current:IsA("TextButton")) then
            return current.Text
        end
        return nil
    end)
    if success then
        return result
    end
    return nil
end

-- Function to get guild info
local function getGuildInfo()
    local info = {
        guildName = "Unknown",
        tag = "Unknown",
        score = "0",
        rank = "Unknown",
        memberCount = "0",
        members = {}
    }
    
    -- This reads straight from the instance tree (like Dex does), so it
    -- works whether or not ViewGuildPage is currently Visible on screen.
    local viewGuildPage = LocalPlayer.PlayerGui:FindFirstChild("ViewGuildPage")
    if not viewGuildPage then return info end
    
    local mainPage = viewGuildPage:FindFirstChild("MainPage")
    if not mainPage then return info end
    
    local content = mainPage:FindFirstChild("Content")
    if not content then return info end
    
    -- GuildInfo wraps both GuildName_Rank and TotalContribution
    local guildInfo = content:FindFirstChild("GuildInfo")
    
    -- Get guild name and tag
    -- Path: Content.GuildInfo.GuildName_Rank.TextLabel
    local nameRankText = getTextFrom(guildInfo, "GuildName_Rank")
    if nameRankText then
        -- Parse guild name and tag from text (format: "GuildName [TAG]")
        local tagMatch = string.match(nameRankText, "%[(.-)%]")
        if tagMatch then
            info.tag = tagMatch
            info.guildName = string.match(nameRankText, "^(.-)%s*%[") or nameRankText
        else
            info.guildName = nameRankText
        end
    end
    
    -- Get total contribution and rank
    -- Path: Content.GuildInfo.TotalContribution.TextLabel
    local contributionText = getTextFrom(guildInfo, "TotalContribution")
    if contributionText then
        -- Parse score and rank from text like "Score: 69.41M  •  Rank #11,092"
        local scoreMatch = string.match(contributionText, "Score:%s*(.-)%s*•")
        local rankMatch = string.match(contributionText, "Rank%s*#(%d+,?%d*)")
        if scoreMatch then
            info.score = string.gsub(scoreMatch, "%s", "")
        end
        if rankMatch then
            info.rank = "#" .. rankMatch
        end
    end
    
    -- Get member count
    local memberCountText = getTextFrom(content, "MemberCountTextLabel1")
    if memberCountText then
        info.memberCount = memberCountText
    end
    
    -- Get members from scrolling frame
    -- Path: Content.ScrollingFrame.Member_<id>.ContainerFrame
    local scrollingFrame = content:FindFirstChild("ScrollingFrame")
    if scrollingFrame then
        -- Get all member frames
        local memberFrames = {}
        for _, child in ipairs(scrollingFrame:GetChildren()) do
            if child:IsA("Frame") and string.match(child.Name, "^Member_%d+$") then
                table.insert(memberFrames, child)
            end
        end
        
        -- Sort members by name (optional)
        table.sort(memberFrames, function(a, b)
            return a.Name < b.Name
        end)
        
        -- Get each member's username, role/rank, and weekly contribution
        for _, memberFrame in ipairs(memberFrames) do
            local containerFrame = memberFrame:FindFirstChild("ContainerFrame")
            if containerFrame then
                -- Get username
                local username = getTextFrom(containerFrame, "Username") or "Unknown"
                
                -- Get role/rank (e.g. Owner, Officer, Member)
                -- Path: ContainerFrame.Role_Rank
                local roleRank = getTextFrom(containerFrame, "Role_Rank") or "Unknown"
                
                -- Get weekly contribution
                local contributions = containerFrame:FindFirstChild("Contributions")
                local weeklyContribution = "0"
                if contributions then
                    local weeklyText = getTextFrom(contributions, "Weekly")
                    if weeklyText then
                        weeklyContribution = weeklyText
                    end
                end
                
                -- Add to members list
                table.insert(info.members, {
                    username = username,
                    role = roleRank,
                    contribution = weeklyContribution
                })
            end
        end
    end
    
    return info
end

-- Function to compare two data tables for changes
local function hasDataChanged(oldData, newData)
    if not oldData or not newData then return true end
    
    if oldData.guildName ~= newData.guildName then return true end
    if oldData.tag ~= newData.tag then return true end
    if oldData.score ~= newData.score then return true end
    if oldData.rank ~= newData.rank then return true end
    if oldData.memberCount ~= newData.memberCount then return true end
    
    if not oldData.members or not newData.members then return true end
    if #oldData.members ~= #newData.members then return true end
    
    for i = 1, #oldData.members do
        if oldData.members[i].username ~= newData.members[i].username then return true end
        if oldData.members[i].role ~= newData.members[i].role then return true end
        if oldData.members[i].contribution ~= newData.members[i].contribution then return true end
    end
    
    return false
end

-- Function to format the message for Discord
local function formatMessage(data)
    if not data or #data.members == 0 then
        return "No guild data available"
    end
    
    local message = string.format(
        "**[%s] %s**\n" ..
        "Score: %s  •  Rank: %s\n" ..
        "Members: %s\n" ..
        "─────────────────\n",
        data.tag or "???",
        data.guildName or "Unknown",
        data.score or "0",
        data.rank or "N/A",
        data.memberCount or "0"
    )
    
    -- Add member list
    local memberLines = {}
    for _, member in ipairs(data.members) do
        table.insert(memberLines, string.format(
            "%s [%s]     %s",
            member.username or "Unknown",
            member.role or "Unknown",
            member.contribution or "0"
        ))
    end
    
    -- If we have too many members, limit the list
    if #memberLines > 20 then
        for i = 1, 20 do
            message = message .. memberLines[i] .. "\n"
        end
        message = message .. string.format("... and %d more members", #memberLines - 20)
    else
        message = message .. table.concat(memberLines, "\n")
    end
    
    return message
end

-- Resolve the best available HTTP function for this executor.
-- Roblox's HttpService:PostAsync is sometimes blocked depending on the
-- calling thread context, so prefer the executor's own request function
-- (http_request / request / syn.request) when present.
local function doHttpPost(url, jsonBody)
    local requestFn = (typeof(http_request) == "function" and http_request)
        or (typeof(request) == "function" and request)
        or (typeof(syn) == "table" and typeof(syn.request) == "function" and syn.request)

    if requestFn then
        local success, response = pcall(requestFn, {
            Url = url,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = jsonBody
        })
        return success, response
    end

    -- Fallback to native Roblox HttpService. Spawned on a fresh thread
    -- since PostAsync is sometimes blocked when called from inside a
    -- RunService connection callback's thread on some executors.
    local success, result
    task.spawn(function()
        success, result = pcall(function()
            return HttpService:PostAsync(url, jsonBody, Enum.HttpContentType.ApplicationJson)
        end)
    end)

    -- Give the spawned thread a moment to run before we report status.
    local waited = 0
    while success == nil and waited < 5 do
        task.wait(0.1)
        waited += 0.1
    end

    return success or false, result
end

-- Function to send data to Discord webhook
local function sendToDiscord(data)
    if WEBHOOK_URL == "YOUR_DISCORD_WEBHOOK_URL_HERE" then
        warn("Please set your Discord webhook URL in the script!")
        return
    end
    
    local message = formatMessage(data)
    
    local payload = {
        content = message
    }
    
    local jsonData = HttpService:JSONEncode(payload)
    
    local success, result = doHttpPost(WEBHOOK_URL, jsonData)
    
    if not success then
        warn("Failed to send webhook: " .. tostring(result))
    end
end

-- Main update function
local function updateGuildInfo()
    local newData = getGuildInfo()
    
    -- Check if data has changed or if it's the first update
    if hasDataChanged(lastData, newData) then
        currentData = newData
        task.spawn(sendToDiscord, newData)
        lastData = table.clone(newData) -- Shallow clone for comparison
        lastCheckTime = tick()
    end
end

-- Function to start the monitoring loop
local function startMonitoring()
    -- Initial update
    updateGuildInfo()
    
    -- Set up interval check
    RunService.Heartbeat:Connect(function()
        if tick() - lastCheckTime >= CHECK_INTERVAL then
            updateGuildInfo()
        end
    end)
    
    -- Also check for GUI changes (when the guild page is opened/refreshed)
    local function onGuiChanged()
        -- Small delay to allow GUI to update
        task.wait(0.5)
        updateGuildInfo()
    end
    
    -- Monitor for changes to the ViewGuildPage.
    -- Wrapped in pcall since "Visible" isn't guaranteed to exist on every
    -- instance type (e.g. Folder), and we don't want that to break the
    -- rest of startMonitoring if it's missing.
    local viewGuildPage = LocalPlayer.PlayerGui:FindFirstChild("ViewGuildPage")
    if viewGuildPage then
        local watchSuccess, watchErr = pcall(function()
            viewGuildPage:GetPropertyChangedSignal("Visible"):Connect(onGuiChanged)
        end)
        if not watchSuccess then
            warn("Could not watch ViewGuildPage.Visible (skipping): " .. tostring(watchErr))
        end
    end
    
    print("Guild Info Monitor started! Sending updates every " .. CHECK_INTERVAL .. " seconds.")
    print("Webhook URL: " .. WEBHOOK_URL)
end

-- Check if we're in a game with the required GUI
local function checkAndStart()
    local success, err = pcall(function()
        local viewGuildPage = LocalPlayer.PlayerGui:FindFirstChild("ViewGuildPage")
        if viewGuildPage then
            startMonitoring()
        else
            -- Wait for the GUI to appear
            print("Waiting for ViewGuildPage to appear...")
            local found = false
            local guiAddedConnection
            guiAddedConnection = LocalPlayer.PlayerGui.ChildAdded:Connect(function(child)
                if child.Name == "ViewGuildPage" then
                    found = true
                    guiAddedConnection:Disconnect()
                    task.wait(1) -- Wait for GUI to fully load
                    startMonitoring()
                end
            end)
            
            -- Timeout after 30 seconds if GUI doesn't appear
            task.wait(30)
            if not found then
                guiAddedConnection:Disconnect()
                print("Timeout: ViewGuildPage not found. Make sure you're in a guild.")
            end
        end
    end)
    
    if not success then
        warn("Failed to start monitoring: " .. tostring(err))
    end
end

-- Start the script
print("Guild Info Webhook Script loaded!")
checkAndStart()
